:root {
  --gold-light: #fff3c4;
  --gold-dark: #c8a94c;
  --green-main: #5a7f49;
  --green-soft: #6fbf5f;
  --green-deep: #1e3c1e;
  --cream: #f5f2e7;
  --shadow-dark: rgba(0, 0, 0, 0.45);
  --brand-dark: #144c36;
  --brand: #1f7a53;
  --brand-soft: #70a88b;
  --mint: #d7efe1;
  --surface: rgba(255, 255, 255, 0.52);
  --surface-strong: rgba(255, 255, 255, 0.72);
  --border-soft: rgba(255, 255, 255, 0.35);
  --text-strong: #123223;
  --text-main: #214535;
  --text-muted: #597567;
  --shadow-soft: 0 18px 40px rgba(9, 37, 24, 0.14);
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  min-height: 100%;
  font-family: "Playfair Display", serif;
}

body.template-index {
  background-image: url("{{ 'ew-background.jpg' | asset_url }}");
  background-position: center top;
  background-size: cover;
  background-repeat: no-repeat;
  color: var(--cream);
}

body:not(.template-index):not(.template-policies) {
  color: var(--text-main);
  background:
    linear-gradient(135deg, rgba(8, 27, 20, 0.82), rgba(17, 79, 55, 0.52)),
    url("{{ 'ew-background.jpg' | asset_url }}") center / cover fixed;
}

body:not(.template-index):not(.template-policies)::before {
  content: "";
  position: fixed;
  inset: 0;
  background:
    radial-gradient(circle at top left, rgba(215, 239, 225, 0.28), transparent 30%),
    radial-gradient(circle at bottom right, rgba(31, 122, 83, 0.24), transparent 28%);
  pointer-events: none;
}

body.template-policies {
  color: var(--cream);
  background:
    linear-gradient(rgba(0, 0, 0, 0.42), rgba(0, 0, 0, 0.72)),
    url("{{ 'ew-background.jpg' | asset_url }}") center / cover fixed;
}

a {
  color: inherit;
}

button,
input,
select,
textarea {
  font: inherit;
}

.hero {
  min-height: 100vh;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 3rem 1.5rem;
}

.overlay {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at center, rgba(1, 29, 10, 0.68) 5%, rgba(0, 0, 0, 0.92));
}

.hero-content {
  position: relative;
  z-index: 2;
  max-width: 860px;
  display: grid;
  justify-items: center;
}

.logo {
  width: min(390px, 72vw);
  margin-bottom: 1.8rem;
  filter: drop-shadow(0 0 47px rgba(56, 228, 93, 0.75));
  transition: transform 0.6s ease, filter 0.4s ease;
}

.hero h1,
.policy-hero h1 {
  font-family: "Great Vibes", cursive;
  background: linear-gradient(var(--gold-light), var(--gold-dark));
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.hero h1 {
  font-size: clamp(3.5rem, 8vw, 4.8rem);
  text-shadow: 0 0 45px rgba(255, 215, 120, 0.6);
  margin-bottom: 1.5rem;
  transition: transform 0.6s ease;
}

.hero-content > p {
  max-width: 640px;
  font-size: 1.05rem;
  line-height: 1.8;
  margin-bottom: 1.5rem;
}

.search-block {
  position: relative;
  width: min(100%, 460px);
  margin-bottom: 1.25rem;
}

.search {
  display: flex;
  justify-content: center;
}

.search input {
  width: 100%;
  padding: 0.95rem 1rem;
  border: none;
  border-radius: 30px 0 0 30px;
  outline: none;
  font-family: inherit;
  font-size: 1rem;
}

.search button {
  padding: 0.95rem 1.2rem;
  border: none;
  border-radius: 0 30px 30px 0;
  background: var(--green-main);
  color: white;
  cursor: pointer;
}

.search-results {
  position: absolute;
  top: calc(100% + 10px);
  left: 0;
  right: 0;
  background: rgba(10, 17, 10, 0.9);
  border: 1px solid rgba(140, 255, 120, 0.2);
  border-radius: 22px;
  backdrop-filter: blur(12px);
  box-shadow: 0 18px 40px rgba(0, 0, 0, 0.45);
  overflow: hidden;
  z-index: 5;
}

.search-result {
  width: 100%;
  border: none;
  background: transparent;
  color: var(--cream);
  text-align: left;
  padding: 0.95rem 1rem;
  cursor: pointer;
  font-family: inherit;
  transition: background 0.2s ease;
}

.search-result:hover,
.search-result.is-selected {
  background: rgba(111, 191, 95, 0.2);
}

.search-empty {
  padding: 0.95rem 1rem;
  color: rgba(245, 242, 231, 0.75);
}

.cta {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.85rem;
  margin-bottom: 1.4rem;
}

.cta a,
.cta button,
.primary {
  padding: 0.95rem 2rem;
  border-radius: 40px;
  border: none;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  font-weight: 600;
  letter-spacing: 1px;
  transition: all 0.4s ease;
  box-shadow: 0 0 15px rgba(0, 0, 0, 0.3);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.6rem;
  text-decoration: none;
  font-family: inherit;
}

.cta a::before,
.cta button::before,
.primary::before {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(120deg, transparent, rgba(255, 255, 255, 0.4), transparent);
  transition: 0.6s;
}

.cta a:hover::before,
.cta button:hover::before,
.primary:hover::before {
  left: 100%;
}

.cta a:hover,
.cta button:hover,
.primary:hover {
  transform: translateY(-6px) scale(1.05);
  box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6);
}

.primary {
  background: var(--green-main);
  color: white;
}

.secondary {
  background: #9b6a4c;
  color: white;
}

.cart-badge {
  min-width: 1.8rem;
  height: 1.8rem;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.18);
  font-size: 0.9rem;
}

.cart-preview {
  padding: 0.9rem 1.2rem;
  border-radius: 22px;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10px);
  display: inline-grid;
  gap: 0.2rem;
  min-width: 190px;
}

.cart-preview span,
.cart-preview small {
  color: rgba(245, 242, 231, 0.86);
}

.cart-preview strong {
  font-size: 1.8rem;
  color: white;
}

.products,
.cart-section {
  padding: 5rem 2.5rem;
  background: rgba(0, 0, 0, 0.7);
}

.section-header,
.cart-heading {
  max-width: 1180px;
  margin: 0 auto 2.5rem;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 1rem;
}

.section-header p,
.cart-heading p,
.collection-header p {
  margin-top: 0.7rem;
  color: rgba(245, 242, 231, 0.8);
}

.products h2,
.cart-section h2 {
  font-size: 2.5rem;
}

.section-link {
  color: var(--cream);
  text-decoration: none;
  font-weight: 600;
}

.product-grid {
  max-width: 1180px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1.9rem;
}

.card {
  background: rgba(30, 60, 30, 0.85);
  padding: 1.55rem;
  border-radius: 25px;
  text-align: center;
  transition: all 0.5s ease;
  position: relative;
  overflow: hidden;
  cursor: pointer;
  box-shadow: 0 16px 35px rgba(0, 0, 0, 0.24);
}

.card:hover {
  transform: translateY(-12px) scale(1.03);
  box-shadow: 0 25px 60px rgba(0, 0, 0, 0.6);
}

.card::after {
  content: "";
  position: absolute;
  top: -100%;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.1), transparent);
  transition: 0.6s;
}

.card:hover::after {
  top: 100%;
}

.card img {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  border-radius: 15px;
  margin-bottom: 1rem;
}

.card h3 {
  margin-bottom: 0.65rem;
}

.card p {
  color: rgba(245, 242, 231, 0.9);
}

.card button,
.card form button {
  margin-top: 1rem;
  padding: 0.8rem 1.5rem;
  border: none;
  border-radius: 30px;
  background: linear-gradient(45deg, #4c7a3c, #6fbf5f);
  color: white;
  cursor: pointer;
  transition: all 0.3s ease;
  font-weight: 600;
  letter-spacing: 0.5px;
  font-family: inherit;
}

.card button:hover,
.card form button:hover {
  transform: scale(1.1);
  box-shadow: 0 0 25px rgba(140, 255, 120, 0.8);
}

.card.active {
  border: 2px solid #8bd66f;
  box-shadow: 0 0 30px rgba(140, 255, 120, 0.8);
}

.card.is-hidden {
  display: none;
}

.card.is-focus {
  border: 2px solid #8bd66f;
  box-shadow: 0 0 35px rgba(140, 255, 120, 0.75);
}

.cart-container {
  max-width: 1180px;
  margin: 0 auto;
  padding: 2rem;
  background: rgba(15, 23, 15, 0.62);
  border-radius: 28px;
  backdrop-filter: blur(14px);
  box-shadow: 0 18px 46px rgba(0, 0, 0, 0.35);
}

.cart-clear,
.cart-buy {
  border: none;
  cursor: pointer;
  border-radius: 999px;
  font-family: inherit;
  font-weight: 700;
}

.cart-clear {
  padding: 0.8rem 1.2rem;
  background: rgba(255, 255, 255, 0.08);
  color: var(--cream);
}

.cart-items {
  display: grid;
  gap: 1rem;
}

.cart-item {
  display: grid;
  grid-template-columns: 80px minmax(0, 1fr) auto auto;
  align-items: center;
  gap: 1rem;
  padding: 1rem;
  border-radius: 20px;
  background: rgba(255, 255, 255, 0.06);
}

.cart-item img {
  width: 80px;
  height: 80px;
  border-radius: 14px;
  object-fit: cover;
}

.cart-item-copy {
  display: grid;
  gap: 0.25rem;
}

.cart-item-title {
  font-weight: 700;
}

.cart-item-meta {
  color: rgba(245, 242, 231, 0.76);
}

.cart-item-price {
  font-weight: 700;
}

.cart-item-remove {
  border: none;
  background: transparent;
  color: #f2a6a6;
  cursor: pointer;
  font-family: inherit;
  font-weight: 700;
}

.cart-empty {
  color: rgba(245, 242, 231, 0.82);
  margin-bottom: 1rem;
}

.cart-summary {
  margin-top: 1.5rem;
  padding-top: 1.5rem;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
}

.cart-summary span {
  display: block;
  color: rgba(245, 242, 231, 0.76);
  margin-bottom: 0.3rem;
}

.cart-summary strong {
  font-size: 1.4rem;
}

.cart-buy {
  padding: 0.95rem 1.8rem;
  background: linear-gradient(45deg, #4c7a3c, #6fbf5f);
  color: white;
}

.whatsapp-btn {
  position: fixed;
  right: 25px;
  bottom: 25px;
  width: 65px;
  height: 65px;
  background: #25d366;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  text-decoration: none;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.4);
  z-index: 9999;
  transition: all 0.3s ease;
}

.whatsapp-btn:hover {
  transform: scale(1.1);
}

.privacy-button {
  position: fixed;
  top: 15px;
  right: 15px;
  background: #111;
  color: white;
  padding: 10px 16px;
  border-radius: 20px;
  font-size: 14px;
  text-decoration: none;
  z-index: 999;
  transition: 0.3s;
}

.privacy-button:hover {
  background: #444;
}

.public-page {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  padding: 1.5rem;
  display: grid;
  align-content: start;
  gap: 1.5rem;
}

.public-page-header-only {
  min-height: auto;
  padding-bottom: 0;
}

.glass-surface,
.glass-panel,
.product-shell,
.collection-shell {
  border-radius: 30px;
  background: var(--surface);
  border: 1px solid var(--border-soft);
  backdrop-filter: blur(16px);
  box-shadow: var(--shadow-soft);
}

.glass-panel {
  padding: 1.25rem;
}

.site-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  padding: 1rem 1.35rem;
}

.site-brand {
  display: flex;
  align-items: center;
  gap: 0.9rem;
  text-decoration: none;
}

.site-brand-logo {
  width: 58px;
  height: 58px;
  border-radius: 18px;
  object-fit: cover;
}

.site-brand-title,
.site-brand-subtitle {
  display: block;
}

.site-brand-title {
  color: var(--text-strong);
  font-weight: 900;
  letter-spacing: 0.04em;
}

.site-brand-subtitle {
  color: var(--text-muted);
  font-size: 0.9rem;
}

.site-nav {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.site-nav a,
.cart-toggle,
.cart-chip {
  display: inline-flex;
  align-items: center;
  gap: 0.55rem;
  min-height: 44px;
  padding: 0.75rem 1rem;
  border-radius: 999px;
  border: 1px solid rgba(20, 76, 54, 0.1);
  text-decoration: none;
  color: var(--brand-dark);
  background: rgba(255, 255, 255, 0.78);
  font-weight: 700;
}

.cart-toggle {
  cursor: pointer;
}

.cart-counter {
  min-width: 1.6rem;
  min-height: 1.6rem;
  padding: 0.15rem 0.35rem;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--brand), var(--brand-dark));
  color: white;
  font-size: 0.82rem;
}

.page-frame {
  display: grid;
  grid-template-columns: minmax(0, 1.8fr) minmax(320px, 0.95fr);
  gap: 1.5rem;
}

.page-frame-single {
  grid-template-columns: minmax(0, 1fr);
}

.section-eyebrow {
  margin: 0 0 0.35rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-size: 0.78rem;
  font-weight: 800;
  color: var(--brand);
}

.section-title {
  margin: 0;
  color: var(--text-strong);
}

.hero-text,
.rte {
  margin: 0;
  color: var(--text-muted);
  line-height: 1.7;
}

.site-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  color: rgba(255, 255, 255, 0.86);
}

.storefront-footer {
  padding: 1rem 2.5rem 2.5rem;
}

.site-footer a {
  color: white;
  font-weight: 700;
}

.about-hero {
  display: grid;
  grid-template-columns: minmax(0, 1.4fr) 220px;
  gap: 1.5rem;
  align-items: center;
  padding: 2rem;
}

.about-hero-logo {
  width: 100%;
  max-width: 220px;
  justify-self: end;
  filter: drop-shadow(0 18px 32px rgba(20, 76, 54, 0.2));
}

.about-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1.25rem;
}

.about-card {
  display: grid;
  gap: 0.75rem;
}

.about-card h2 {
  margin: 0;
  color: var(--text-strong);
}

.about-card p {
  margin: 0;
  color: var(--text-main);
  line-height: 1.65;
}

.policy-page {
  min-height: 100vh;
}

.policy-hero {
  min-height: 42vh;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 2rem 1rem;
}

.policy-overlay {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at center, rgba(17, 46, 24, 0.32), rgba(0, 0, 0, 0.72));
}

.policy-hero-content {
  position: relative;
  z-index: 1;
  display: grid;
  justify-items: center;
  gap: 0.9rem;
}

.policy-logo {
  width: min(220px, 56vw);
  filter: drop-shadow(0 0 32px rgba(56, 228, 93, 0.42));
}

.policy-hero h1 {
  margin: 0;
  font-size: clamp(3rem, 7vw, 4.5rem);
}

.update {
  color: rgba(245, 242, 231, 0.8);
}

.policy-container {
  width: min(920px, calc(100% - 2rem));
  margin: -3rem auto 3rem;
  padding: 2rem;
  background: rgba(8, 12, 9, 0.72);
  border-radius: 28px;
  backdrop-filter: blur(16px);
  box-shadow: 0 25px 70px rgba(0, 0, 0, 0.35);
}

.policy-block + .policy-block {
  margin-top: 1.8rem;
}

.policy-block h2 {
  margin: 0 0 0.8rem;
  font-size: 1.45rem;
  color: var(--gold-light);
}

.policy-block p,
.policy-block li {
  line-height: 1.8;
  color: rgba(245, 242, 231, 0.92);
}

.policy-block ul {
  margin: 0;
  padding-left: 1.3rem;
}

.brand {
  margin-top: 2rem;
  font-weight: 700;
  color: var(--gold-light);
}

.product-shell {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(320px, 0.9fr);
  gap: 1.5rem;
  padding: 1.5rem;
}

.product-media {
  min-width: 0;
}

.product-featured-image {
  width: 100%;
  height: auto;
  border-radius: 24px;
  object-fit: cover;
}

.product-copy {
  display: grid;
  align-content: start;
  gap: 1rem;
}

.product-price {
  font-size: 2rem;
  font-weight: 700;
  color: var(--brand-dark);
}

.product-form {
  display: inline-flex;
}

.button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  border: none;
  border-radius: 999px;
  padding: 0.85rem 1.25rem;
  cursor: pointer;
  font-weight: 700;
}

.collection-shell {
  padding: 1.5rem;
}

.collection-header {
  max-width: none;
}

.collection-empty {
  color: var(--text-muted);
}

.storefront-search-form {
  max-width: 520px;
  margin: 0 0 1.5rem;
}

.animate-in {
  animation: ew-fade-up 0.7s ease forwards;
}

@keyframes ew-fade-up {
  from {
    opacity: 0;
    transform: translateY(18px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (max-width: 980px) {
  .page-frame,
  .product-shell {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 920px) {
  .about-hero {
    grid-template-columns: 1fr;
  }

  .about-hero-logo {
    justify-self: start;
  }

  .about-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 820px) {
  .section-header,
  .cart-heading,
  .cart-summary {
    flex-direction: column;
    align-items: flex-start;
  }

  .products,
  .cart-section {
    padding: 4rem 1.25rem;
  }

  .cart-item {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 768px) {
  .public-page {
    padding: 1rem;
    gap: 1rem;
  }

  .site-header,
  .site-footer {
    flex-direction: column;
    align-items: flex-start;
  }
}
