{% assign source_collection = section.settings.collection | default: collections.all %}
{% assign about_page = section.settings.about_page %}

<section class="products" id="productos">
  <div class="section-header">
    <div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
    </div>
    {% if about_page != blank %}
      <a href="{{ about_page.url }}" class="section-link">{{ section.settings.link_label }}</a>
    {% endif %}
  </div>

  <div class="product-grid">
    {% for product in source_collection.products limit: section.settings.products_to_show %}
      {% render 'product-card', product: product %}
    {% else %}
      {% for i in (1..4) %}
        <article class="card" data-product-name="Producto artesanal">
          <img src="{{ 'product-bikini.jpg' | asset_url }}" alt="Producto artesanal">
          <h3>Producto artesanal</h3>
          <p>{{ 0 | money }}</p>
          <button class="add-to-cart" type="button" disabled>Proximamente</button>
        </article>
      {% endfor %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Product grid",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Coleccion" },
    { "type": "range", "id": "products_to_show", "label": "Productos a mostrar", "min": 4, "max": 12, "step": 1, "default": 4 },
    { "type": "text", "id": "heading", "label": "Titulo", "default": "Nuestros Productos" },
    { "type": "textarea", "id": "subheading", "label": "Subtitulo", "default": "Piezas tejidas a mano con una presencia visual mistica y artesanal." },
    { "type": "page", "id": "about_page", "label": "Pagina de marca" },
    { "type": "text", "id": "link_label", "label": "Texto del enlace", "default": "Conocer la marca" }
  ],
  "presets": [{ "name": "Product grid" }]
}
{% endschema %}
